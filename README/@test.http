@host = https://wallet-server-v1.hashubs.workers.dev

@addressNativeSOL = solana:mainnet/slip44:501
@addressSOL = solana:mainnet/spl-token:omfgRBnxHsNJh6YeGbGAmWenNkenzsXyBXm3WDhmeta

@addressNativeEVM = eip155:137/slip44:966
@addressEVM = eip155:1/erc20:0x2b566950ba2298acef3c730cc0129b2f4fbd30a3

@walletAddressEVM = 0x60E39eaD71123e5F7C8470F2aa83effb90fCb8d1
@walletAddressSOL = EppJnCU4iXxYM1NWuVUnV9qzW1BCFiELMKWQW4dxMMWX

@SOLANA_CHAIN = 792703809

### Test Nightly
# GET {{host}}/test/nightly/market-data?address=BgtczEGgf9mZMcGBLi4J5Pn8PtmFy6Xz5uBKkMfspump&chain=solana
# Accept: application/json

### 1. GET Token Info (Relay API)
GET {{host}}/test/token?assetId={{addressEVM}}&include=metadata,market,pair
Accept: application/json

### 2. POST Search Token By Address
POST {{host}}/api/currencies/v2
Content-Type: application/json

{
  "chainIds":[143],
  "address":"0x754704Bc059F8C67012fEd69BC8A327a5aafb603",
  "defaultList":false,
  "limit":12,
  "useExternalSearch":true
}

### 3. POST Search Token List
POST {{host}}/api/currencies/v2
Content-Type: application/json
{
  "chainIds":[792703809],
  "term":"usdc",
  "defaultList":false,
  "limit":12,
  "depositAddressOnly":true
}

### 4. GET Trending Tokens
GET {{host}}/api/currencies/trending?sortBy=coingecko6hTrending&limit=20
Accept: application/json

### 5. GET EVM Wallet Balances
GET {{host}}/wallet/evm/{{walletAddressEVM}}/balances?chainIds=10
Accept: application/json

### 5.1 GET EVM Wallet Balances with offset
GET {{host}}/wallet/evm/{{walletAddressEVM}}/balances?limit=1&offset=AQAAAAAAAAA
Accept: application/json

### 6. GET SVM Wallet Balances (Solana)
GET {{host}}/wallet/svm/{{walletAddressSOL}}/balances
Accept: application/json

### 6.1 GET SVM Wallet Balances (Solana) with offset
GET {{host}}/wallet/svm/{{walletAddressSOL}}/balances?limit=1&offset=AQAAAAAAAAA
Accept: application/json

### 7. GET EVM Wallet Activity (Zerion)
GET {{host}}/wallet/activity?evmAddress={{walletAddressEVM}}&limit=10
Accept: application/json

### 8. GET EVM Wallet Activity (Zerion) Filter by Chain (CAIP-2)
GET {{host}}/wallet/activity?evmAddress={{walletAddressEVM}}&chain=eip155:8453&limit=10
Accept: application/json

### 9. GET EVM Wallet Activity (Zerion) Filter by Asset (CAIP-19)
GET {{host}}/wallet/activity?evmAddress={{walletAddressEVM}}&fungibleId=eth&limit=10
Accept: application/json

### 10. GET SVM Wallet Activity (Zerion)
GET {{host}}/wallet/activity?svmAddress={{walletAddressSOL}}&limit=10
Accept: application/json

### Activity Transactions - EVM only
POST {{host}}/wallet/activity
Content-Type: application/json

{
  "addresses": ["0x60e39ead71123e5f7c8470f2aa83effb90fcb8d1"],
  "currency": "usd",
  "fungibleId": "eip155:1/slip44:60:asset_w83SN0cYOjqvAKx0Tfl8Qg",
  "limit": 100
}

### Activity Transactions - SVM only
POST {{host}}/wallet/activity
Content-Type: application/json

{
  "addresses": ["DC715bNY31k7gHkJXbPqRunEFCg1686VYpLYKMJptmLX"],
  "currency": "usd",
  "limit": 10
}

### Activity Transactions - EVM + SVM (mixed)
POST {{host}}/wallet/activity
Content-Type: application/json

{
  "addresses": [
    "0x60e39ead71123e5f7c8470f2aa83effb90fcb8d1",
    "DC715bNY31k7gHkJXbPqRunEFCg1686VYpLYKMJptmLX"
  ],
  "currency": "usd",
  "limit": 100
}

### Activity Transactions - with chain filter
POST {{host}}/wallet/activity
Content-Type: application/json

{
  "addresses": ["0x60e39ead71123e5f7c8470f2aa83effb90fcb8d1"],
  "currency": "usd",
  "chain": "ethereum",
  "limit": 50
}

### Activity Transactions - with actionTypes filter
POST {{host}}/wallet/portfolio/values
Content-Type: application/json

{
  "addresses": ["0x60e39ead71123e5f7c8470f2aa83effb90fcb8d1", "0x1b10845bd3bfd221ccb679a963b76cb1264cfc88"],
  "currency": "usd",
  "mode": "mainnet"
}

