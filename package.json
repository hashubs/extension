{
  "name": "youno",
  "version": "1.0.0",
  "description": "A web3 wallet extension",
  "scripts": {
    "start": "npm-run-all --parallel start:chrome type-check:watch",
    "start:chrome": "rm -rf .parcel-cache dist && cp ./src/manifest-chrome.json ./src/manifest.json && PLATFORM=chrome parcel watch src/manifest.json --no-hmr --public-url ./ --no-content-hash --no-autoinstall",
    "start:firefox": "rm -rf .parcel-cache dist-firefox && cp ./src/manifest-firefox.json ./src/manifest.json && PLATFORM=firefox parcel watch src/manifest.json --no-hmr --public-url ./ --no-content-hash --no-autoinstall --dist-dir dist-firefox",
    "build": "echo \"Please run 'npm run build:production' instead\" && exit 1",
    "build:chrome": "node scripts/build.js",
    "build:firefox": "node scripts/build-firefox.js",
    "build:production": "npm-run-all --sequential build:chrome build:firefox",
    "type-check": "tsc --noEmit",
    "type-check:watch": "tsc --noEmit --pretty --watch",
    "test:unit": "node --experimental-vm-modules node_modules/jest/bin/jest.js",
    "test:e2e": "playwright test",
    "test:e2e:update": "playwright test --update-snapshots",
    "test:e2e:ui": "playwright test --ui",
    "ui-lab": "parcel serve src/ui-lab/index.html --config ./src/ui-lab/parcel.lab.config",
    "lint": "eslint . --cache --fix",
    "format": "prettier --loglevel warn --write \"**/*.{ts,tsx,css,md}\"",
    "prepare": "husky install",
    "postversion": "node ./scripts/manifest-version.js"
  },
  "alias": {
    "src": "./src",
    "zksync-ethers": "zksync-ethers/build",
    "ethers": "ethers/lib.commonjs",
    "buffer-todo-set-to-false": false
  },
  "@parcel/bundler-default": {
    "minBundles": 10000000,
    "minBundleSize": 3000,
    "maxParallelRequests": 20
  },
  "keywords": [
    "Wallet",
    "Web3",
    "Browser",
    "Wallet"
  ],
  "browserslist": "> 0.5%, last 2 versions, not dead",
  "engines": {
    "node": ">=20.10.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.29.0",
    "@jest/globals": "^30.3.0",
    "@parcel/config-webextension": "^2.14.4",
    "@parcel/optimizer-data-url": "^2.14.4",
    "@parcel/optimizer-esbuild": "^2.14.4",
    "@parcel/transformer-inline-string": "^2.14.4",
    "@parcel/transformer-svg-react": "^2.14.4",
    "@playwright/test": "^1.50.0",
    "@tailwindcss/postcss": "^4.2.2",
    "@tanstack/eslint-plugin-query": "^4.39.1",
    "@trivago/prettier-plugin-sort-imports": "^6.0.2",
    "@types/canvas-confetti": "^1.6.4",
    "@types/chrome": "^0.0.270",
    "@types/dom-navigation": "^1.0.5",
    "@types/jest": "^29.5.12",
    "@types/lodash": "^4.17.7",
    "@types/node": "^22.4.0",
    "@types/react": "^18.2.25",
    "@types/react-dom": "^18.2.11",
    "@types/socket.io-client": "^1.4.36",
    "@types/uuid": "^9.0.2",
    "@types/w3c-web-usb": "^1.0.10",
    "@types/webextension-polyfill": "^0.10.1",
    "@typescript-eslint/parser": "^8.35.0",
    "confusing-browser-globals": "^1.0.11",
    "crypto-browserify": "^3.12.1",
    "dotenv": "^16.4.5",
    "eslint": "^8.57.1",
    "eslint-plugin-import": "^2.32.0",
    "eslint-plugin-react-hooks": "^5.2.0",
    "eslint-plugin-security": "^3.0.1",
    "husky": "^8.0.3",
    "jest": "^29.7.0",
    "lint-staged": "^13.2.3",
    "npm-run-all": "^4.1.5",
    "parcel": "^2.14.4",
    "path-browserify": "^1.0.1",
    "postcss": "^8.5.8",
    "prettier": "^2.8.8",
    "process": "^0.11.10",
    "string_decoder": "^1.3.0",
    "svgo": "^3.3.2",
    "tailwindcss": "^4.2.2",
    "ts-jest": "^29.1.2",
    "tw-animate-css": "^1.4.0",
    "typescript": "^5.8.2",
    "typescript-eslint": "^8.35.0",
    "vm-browserify": "^1.1.2"
  },
  "lint-staged": {
    "*.{ts,tsx}": "eslint --cache --fix",
    "*.{ts,tsx,css,md}": "prettier --write"
  },
  "dependencies": {
    "@base-ui/react": "^1.3.0",
    "@download/blockies": "^1.0.3",
    "@ethersproject/abstract-provider": "^5.7.0",
    "@ethersproject/bignumber": "^5.7.0",
    "@ethersproject/bytes": "^5.8.0",
    "@ethersproject/hdnode": "^5.7.0",
    "@ethersproject/wallet": "^5.7.0",
    "@hookform/resolvers": "^5.2.2",
    "@react-spring/web": "^10.0.3",
    "@solana/spl-token": "^0.4.13",
    "@solana/wallet-standard-features": "^1.3.0",
    "@solana/web3.js": "^1.98.0",
    "@store-unit/react": "^1.0.4",
    "@tanstack/react-query": "^5.90.21",
    "@tanstack/react-virtual": "^3.13.19",
    "@use-gesture/react": "^10.3.1",
    "@wallet-standard/base": "^1.1.0",
    "@wallet-standard/core": "^1.1.1",
    "@wallet-standard/features": "1.1.0",
    "@walletconnect/jsonrpc-provider": "^1.0.13",
    "@walletconnect/jsonrpc-utils": "^1.0.8",
    "bignumber.js": "^9.1.1",
    "bip32": "^5.0.0-rc.0",
    "bip39": "^3.1.0",
    "bs58": "^6.0.0",
    "buffer": "^6.0.3",
    "canvas-confetti": "^1.6.0",
    "capitalize-ts": "^1.0.0",
    "chart.js": "^4.4.8",
    "class-variance-authority": "^0.7.1",
    "classnames": "^2.3.2",
    "clsx": "^2.1.1",
    "dayjs": "^1.11.9",
    "downshift": "^7.6.0",
    "ed25519-hd-key": "^1.3.0",
    "ethers": "^6.14.0",
    "events": "^3.3.0",
    "eventsource": "^4.0.0",
    "get-error": "^1.0.1",
    "immer": "^10.0.2",
    "is-truthy-ts": "^1.0.1",
    "ky": "^0.33.3",
    "lodash": "^4.17.21",
    "lottie-web": "^5.12.2",
    "memoize-one": "^6.0.0",
    "nanoevents": "^8.0.0",
    "nanoid": "^4.0.2",
    "normalize.css": "^8.0.1",
    "normalized-contains": "^1.0.0",
    "p-limit": "^7.3.0",
    "react": "^18.2.0",
    "react-area": "^0.1.1-alpha.6",
    "react-dom": "^18.2.0",
    "react-hook-form": "^7.72.1",
    "react-icons": "^5.6.0",
    "react-qrcode-logo": "^2.9.0",
    "react-router-dom": "^6.18.0",
    "rlp": "^3.0.0",
    "store-unit": "^1.0.3",
    "stream-browserify": "^3.0.0",
    "tailwind-merge": "^3.5.0",
    "tiny-secp256k1": "^2.2.4",
    "tweetnacl": "^1.0.3",
    "uuid": "^9.0.0",
    "vaul": "^1.1.2",
    "webextension-polyfill": "^0.10.0",
    "zksync-ethers": "^6.17.0",
    "zod": "^4.3.6",
    "zustand": "^5.0.12"
  }
}
