import { BlockieAddress } from '@/ui/components/blockie';
import { Header } from '@/ui/components/header';
import { truncateAddress } from '@/ui/lib/utils';
import {
  Button,
  Card,
  CardItem,
  Collapsible,
  CollapsibleContent,
} from '@/ui/ui-kit';
import { ItemType } from '@/ui/ui-kit/card';
import { useState } from 'react';
import {
  FiAlertTriangle,
  FiChevronDown,
  FiChevronUp,
  FiCopy,
} from 'react-icons/fi';
import { IoAddOutline } from 'react-icons/io5';
import { LuChevronRight } from 'react-icons/lu';
import { SiEthereum, SiSolana } from 'react-icons/si';
import { useNavigate } from 'react-router-dom';

interface Wallet {
  address: string;
}

interface Chain {
  id: 'eth' | 'sol';
  wallets: Wallet[];
}

interface WalletGroup {
  id: number;
  name: string;
  importedAt?: string;
  createdAt?: string;
  backedUp: boolean;
  chains: Chain[];
}

const GROUPS: WalletGroup[] = [
  {
    id: 1,
    name: 'Group Alpha',
    importedAt: 'Apr 12, 2026',
    backedUp: true,
    chains: [
      {
        id: 'eth',
        wallets: [
          { address: '0x2e0d2665B1F3235F4a091d160a3406dDd7623F94' },
          { address: '0x72e2db15A806b88D6313fA24eD5EAFba9b78997A' },
          { address: '0x60E39eaD71123e5F7C8470F2aa83effb90fCb8d1' },
          { address: '0x78b572C7fDb2863563EC5b9bC0CcCf4806278c80' },
        ],
      },
      {
        id: 'sol',
        wallets: [
          { address: 'DP7eZhSFzmxtxE58JTryysEz7ZCrXH2F7VWmgTchToJd' },
          { address: 'HiKmCZ79gPxnzhxLhfBkQUNZcbo34aJgNbZBNhhWtLGr' },
        ],
      },
    ],
  },
  {
    id: 2,
    name: 'Group Beta',
    createdAt: 'Apr 12, 2026',
    backedUp: false,
    chains: [
      {
        id: 'eth',
        wallets: [{ address: '0x1aeFB398293C0591532f1dD065D6392c52542683' }],
      },
      {
        id: 'sol',
        wallets: [{ address: '7avVaaHTwDATQbfvay2YLoBonf3rMCEEwUkWXfmy39Yu' }],
      },
    ],
  },
];

const ChainIcon = ({ id }: { id: 'eth' | 'sol' }) =>
  id === 'eth' ? (
    <span className="flex items-center justify-center w-5 h-5 rounded-full bg-[#627eea]">
      <SiEthereum className="text-white" size={10} />
    </span>
  ) : (
    <span className="flex items-center justify-center w-5 h-5 rounded-full bg-[#9945ff]">
      <SiSolana className="text-white" size={10} />
    </span>
  );

const chainLabel = (id: 'eth' | 'sol') =>
  id === 'eth' ? 'Ethereum' : 'Solana';

function ChainBlock({ chain }: { chain: Chain }) {
  const [copied, setCopied] = useState<string | null>(null);

  const handleCopy = (addr: string) => {
    navigator.clipboard.writeText(addr).catch(() => {});
    setCopied(addr);
    setTimeout(() => setCopied(null), 1500);
  };

  return (
    <div className="bg-black/2 dark:bg-white/2 rounded-xl px-3 py-2.5">
      <div className="flex items-center justify-between mb-2">
        <div className="flex items-center gap-2">
          <ChainIcon id={chain.id} />
          <span className="text-sm font-medium text-neutral-700 dark:text-neutral-200">
            {chainLabel(chain.id)}
          </span>
        </div>
        <span className="text-[11px] text-neutral-400 dark:text-neutral-500">
          {chain.wallets.length} wallet{chain.wallets.length > 1 ? 's' : ''}
        </span>
      </div>
      <div className="grid grid-cols-2 gap-x-4 gap-y-1">
        {chain.wallets.map((w) => (
          <button
            key={w.address}
            onClick={() => handleCopy(w.address)}
            className="flex items-center gap-1 group text-left"
          >
            <code className="text-[13px] text-muted-foreground font-mono">
              {copied === w.address ? 'Copied!' : truncateAddress(w.address)}
            </code>
            <FiCopy size={12} className="text-muted-foreground shrink-0" />
          </button>
        ))}
      </div>
    </div>
  );
}

function GroupCard({ group }: { group: WalletGroup }) {
  const [open, setOpen] = useState(true);

  return (
    <Card>
      <button
        onClick={() => setOpen((v) => !v)}
        className="w-full flex items-center justify-between px-4 py-3"
      >
        <div className="flex items-center gap-3">
          <span className="w-7 h-7 rounded-lg bg-neutral-100 dark:bg-neutral-800 flex items-center justify-center text-xs font-semibold text-neutral-600 dark:text-neutral-300">
            {group.id}
          </span>
          <span className="text-sm font-medium text-neutral-800 dark:text-neutral-100">
            {group.name}
          </span>
        </div>
        <div className="flex items-center gap-2">
          {!group.backedUp && (
            <span className="flex items-center gap-1 text-[11px] font-medium text-amber-700 dark:text-amber-400 bg-amber-50 dark:bg-amber-900/30 px-2 py-0.5 rounded-full">
              <FiAlertTriangle size={10} strokeWidth={2.5} />
              Not backed up
            </span>
          )}
          {open ? (
            <FiChevronUp size={14} className="text-neutral-400" />
          ) : (
            <FiChevronDown size={14} className="text-neutral-400" />
          )}
        </div>
      </button>
      <Collapsible open={open} onOpenChange={setOpen}>
        <CollapsibleContent>
          <div className="px-4 pb-4 pt-3 flex flex-col gap-2">
            {group.chains.map((chain) => (
              <ChainBlock key={chain.id} chain={chain} />
            ))}
            <div className="flex items-center justify-between">
              {group.importedAt && (
                <p className="text-[11px] text-neutral-400 dark:text-neutral-600 mt-1">
                  Imported {group.importedAt}
                </p>
              )}
              {group.createdAt && (
                <p className="text-[11px] text-neutral-400 dark:text-neutral-600 mt-1">
                  Created {group.createdAt}
                </p>
              )}

              <button className="text-primary text-[11px] font-medium hover:text-primary/80">
                View All
              </button>
            </div>
          </div>
        </CollapsibleContent>
      </Collapsible>
    </Card>
  );
}

function WatchlistCard() {
  const navigate = useNavigate();

  const navigations: navigationType[] = [
    {
      title: 'Watchlist',
      items: [
        {
          iconNode: BlockieAddress({
            address: '0x2e0d2665B1F3235F4a091d160a3406dDd7623F94',
            size: 18,
            borderRadius: 4,
          }),
          label: truncateAddress('0x2e0d2665B1F3235F4a091d160a3406dDd7623F94'),
          onClick: () => navigate('/settings/manage-wallet/add'),
          iconClassName: 'text-lime-500 bg-lime-500/10',
          iconRight: LuChevronRight,
        },
        {
          iconNode: BlockieAddress({
            address: 'DP7eZhSFzmxtxE58JTryysEz7ZCrXH2F7VWmgTchToJd',
            size: 18,
            borderRadius: 4,
          }),
          label: truncateAddress(
            'DP7eZhSFzmxtxE58JTryysEz7ZCrXH2F7VWmgTchToJd'
          ),
          onClick: () => navigate('/settings/manage-wallet/import'),
          iconClassName: 'text-lime-500 bg-lime-500/10',
          iconRight: LuChevronRight,
        },
        {
          iconNode: BlockieAddress({
            address: '0x393beA8D46e9519cDaed6ed6148686bCfED06AE3',
            size: 18,
            borderRadius: 4,
          }),
          label: truncateAddress('0x393beA8D46e9519cDaed6ed6148686bCfED06AE3'),
          onClick: () => navigate('/settings/manage-wallet/watch'),
          iconClassName: 'text-lime-500 bg-lime-500/10',
          iconRight: LuChevronRight,
        },
      ],
    },
  ];

  return navigations.map((section, i) => (
    <div key={i}>
      <Card title={section.title}>
        {section.items.map((item, j) => (
          <CardItem key={j} item={item} />
        ))}
      </Card>
    </div>
  ));
}

type navigationType = {
  title?: string;
  items: ItemType[];
};

function WalletActions() {
  const navigate = useNavigate();

  const navigations: navigationType[] = [
    {
      items: [
        {
          icon: IoAddOutline,
          label: 'Add Wallet',
          onClick: () => navigate('/settings/manage-wallet/add'),
          iconClassName: 'text-lime-500 bg-lime-500/10',
        },
        {
          icon: IoAddOutline,
          label: 'Import Wallet to Selvo',
          onClick: () => navigate('/settings/manage-wallet/import'),
          iconClassName: 'text-lime-500 bg-lime-500/10',
        },
        {
          icon: IoAddOutline,
          label: 'Add Watch Address',
          onClick: () => navigate('/settings/manage-wallet/watch'),
          iconClassName: 'text-lime-500 bg-lime-500/10',
        },
      ],
    },
  ];

  return (
    <div className="flex flex-col space-y-4">
      {navigations.map((section, i) => (
        <div key={i}>
          <Card title={section.title}>
            {section.items.map((item, j) => (
              <CardItem key={j} item={item} />
            ))}
          </Card>
        </div>
      ))}

      <Button variant="danger" size="md">
        Erase All Data
      </Button>
    </div>
  );
}

export function WalletGroups() {
  const navigate = useNavigate();
  return (
    <div className="flex flex-col h-full">
      <Header
        title="Network"
        onBack={() => navigate('/settings', { state: { direction: 'back' } })}
      />

      <div className="flex-1 p-4 pt-0 space-y-4 no-scrollbar overflow-y-auto">
        {GROUPS.map((group) => (
          <GroupCard key={group.id} group={group} />
        ))}
        <WatchlistCard />

        <WalletActions />
      </div>
    </div>
  );
}
