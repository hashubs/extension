import { memo, ReactNode, useRef, useState } from 'react';

export interface SmartSecretInputProps {
  /** HTML name attribute — used for FormData */
  name?: string;
  /** Whether the field is required */
  required?: boolean;
  /** Auto-focus on mount */
  autoFocus?: boolean;
  /** Show the reveal/hide toggle button */
  showRevealElement?: boolean;
  /** Label rendered above the input */
  label?: ReactNode;
  /** Hint or error rendered below the input */
  hint?: ReactNode;
  /** Called whenever the internal value changes */
  onChange?: (value: string) => void;
}

type Mode = 'idle' | 'key' | 'seed';

const EyeOpen = () => (
  <svg
    width="16"
    height="16"
    viewBox="0 0 24 24"
    fill="none"
    stroke="currentColor"
    strokeWidth="2"
    strokeLinecap="round"
    strokeLinejoin="round"
  >
    <path d="M2 12s3-7 10-7 10 7 10 7-3 7-10 7-10-7-10-7Z" />
    <circle cx="12" cy="12" r="3" />
  </svg>
);

const EyeOff = () => (
  <svg
    width="16"
    height="16"
    viewBox="0 0 24 24"
    fill="none"
    stroke="currentColor"
    strokeWidth="2"
    strokeLinecap="round"
    strokeLinejoin="round"
  >
    <path d="M9.88 9.88a3 3 0 1 0 4.24 4.24" />
    <path d="M10.73 5.08A10.43 10.43 0 0 1 12 5c7 0 10 7 10 7a13.16 13.16 0 0 1-1.67 2.68" />
    <path d="M6.61 6.61A13.526 13.526 0 0 0 2 12s3 7 10 7a9.74 9.74 0 0 0 5.39-1.61" />
    <line x1="2" x2="22" y1="2" y2="22" />
  </svg>
);

interface WordInputProps {
  index: number;
  value: string;
  revealed: boolean;
  isFocused: boolean;
  name?: string;
  onChange: (idx: number, val: string) => void;
  onKeyDown: (e: React.KeyboardEvent<HTMLInputElement>, idx: number) => void;
  onPaste: (e: React.ClipboardEvent<HTMLInputElement>, idx: number) => void;
  onFocus: (idx: number) => void;
  onBlur: () => void;
  inputRef: (el: HTMLInputElement | null) => void;
}

const WordInput = memo(
  ({
    index,
    value,
    revealed,
    isFocused,
    name,
    onChange,
    onKeyDown,
    onPaste,
    onFocus,
    onBlur,
    inputRef,
  }: WordInputProps) => (
    <div className="flex items-stretch border border-gray-200 rounded-lg overflow-hidden bg-white focus-within:border-indigo-400 focus-within:ring-2 focus-within:ring-indigo-100 transition-all">
      <div className="w-8 min-w-[2rem] flex items-center justify-center text-[11px] text-gray-400 bg-gray-50 border-r border-gray-200 select-none shrink-0">
        {index + 1}
      </div>
      <input
        ref={inputRef}
        name={name}
        type={revealed || isFocused ? 'text' : 'password'}
        className="flex-1 min-w-0 h-10 px-2.5 bg-transparent text-sm font-mono text-gray-900 outline-none placeholder:text-gray-300"
        autoComplete="off"
        spellCheck={false}
        placeholder={`word ${index + 1}`}
        value={value}
        onChange={(e) => onChange(index, e.target.value)}
        onKeyDown={(e) => onKeyDown(e, index)}
        onPaste={(e) => onPaste(e, index)}
        onFocus={() => onFocus(index)}
        onBlur={onBlur}
      />
    </div>
  )
);

export function SecretInput({
  name,
  required,
  autoFocus,
  showRevealElement = true,
  label,
  hint,
  onChange,
}: SmartSecretInputProps) {
  const [mode, setMode] = useState<Mode>('idle');
  const [revealed, setRevealed] = useState(false);
  const [gridSize, setGridSize] = useState<12 | 24>(12);
  const [showGrid, setShowGrid] = useState(false);
  const [singleValue, setSingleValue] = useState('');
  const [words, setWords] = useState<string[]>(Array(24).fill(''));
  const [focusedIndex, setFocusedIndex] = useState<number | null>(null);

  const singleRef = useRef<HTMLInputElement>(null);
  const wordRefs = useRef<(HTMLInputElement | null)[]>([]);

  // The joined value emitted to the form / parent
  const joinedValue = showGrid
    ? words.slice(0, gridSize).join(' ').trim()
    : singleValue;

  // ── Helpers ──────────────────────────────────────────────────────────────

  const focusSingle = () => setTimeout(() => singleRef.current?.focus(), 0);
  const focusWord = (idx: number) =>
    setTimeout(() => wordRefs.current[idx]?.focus(), 0);
  const isEmpty = (w: string[], size: number) =>
    w.slice(0, size).every((v) => !v.trim());

  const emitChange = (value: string) => onChange?.(value);

  const resetToSingle = () => {
    setShowGrid(false);
    setWords(Array(24).fill(''));
    setSingleValue('');
    setMode('idle');
    emitChange('');
    focusSingle();
  };

  const switchToSeed = (incoming: string[]) => {
    const size: 12 | 24 = incoming.length > 12 ? 24 : 12;
    const next = Array(24).fill('');
    incoming.slice(0, size).forEach((w, i) => (next[i] = w));
    setGridSize(size);
    setWords(next);
    setSingleValue('');
    setShowGrid(true);
    setMode('seed');
    emitChange(incoming.slice(0, size).join(' '));
    focusWord(Math.min(incoming.length, size - 1));
  };

  const handleSingleChange = (val: string) => {
    setSingleValue(val);
    emitChange(val);
    const ws = val.trim().split(/\s+/).filter(Boolean);
    if (ws.length >= 2) switchToSeed(ws);
    else if (val.trim() && !val.includes(' ')) setMode('key');
    else if (!val.trim()) setMode('idle');
  };

  const handleSinglePaste = (e: React.ClipboardEvent<HTMLInputElement>) => {
    const ws = e.clipboardData
      .getData('text')
      .trim()
      .split(/\s+/)
      .filter(Boolean);
    if (ws.length >= 2) {
      e.preventDefault();
      switchToSeed(ws);
    }
  };

  const handleWordChange = (idx: number, val: string) => {
    setWords((prev) => {
      const next = [...prev];
      next[idx] = val;
      if (isEmpty(next, gridSize)) {
        resetToSingle();
        return prev;
      }
      emitChange(next.slice(0, gridSize).join(' ').trim());
      return next;
    });
  };

  const handleWordKeyDown = (
    e: React.KeyboardEvent<HTMLInputElement>,
    idx: number
  ) => {
    if (e.key === ' ' || e.key === 'Tab') {
      e.preventDefault();
      wordRefs.current[idx + 1]?.focus();
    }
    if (e.key === 'Backspace' && words[idx] === '') {
      e.preventDefault();
      if (idx === 0) {
        if (isEmpty(words, gridSize)) resetToSingle();
      } else {
        setWords((prev) => {
          const next = [...prev];
          next[idx - 1] = '';
          return next;
        });
        wordRefs.current[idx - 1]?.focus();
      }
    }
  };

  const handleWordPaste = (
    e: React.ClipboardEvent<HTMLInputElement>,
    startIdx: number
  ) => {
    const ws = e.clipboardData
      .getData('text')
      .trim()
      .split(/\s+/)
      .filter(Boolean);
    if (ws.length > 1) {
      e.preventDefault();
      setWords((prev) => {
        const next = [...prev];
        ws.forEach((w, i) => {
          if (startIdx + i < 24) next[startIdx + i] = w;
        });
        emitChange(next.slice(0, gridSize).join(' ').trim());
        return next;
      });
    }
  };

  const badgeClass =
    mode === 'key'
      ? 'bg-indigo-50 text-indigo-800 border-indigo-300'
      : mode === 'seed'
      ? 'bg-emerald-50 text-emerald-800 border-emerald-300'
      : 'bg-gray-100 text-gray-500 border-gray-200';

  const badgeText =
    mode === 'key'
      ? 'Private key'
      : mode === 'seed'
      ? 'Seed phrase / mnemonic'
      : 'Waiting for input...';

  const hintDefault =
    mode === 'key'
      ? 'Format: 0x followed by 64 hex characters'
      : mode === 'seed'
      ? 'Press Space or Tab to move to the next word'
      : 'Paste directly — words will spread automatically';

  return (
    <div className="flex flex-col gap-2 w-full">
      {name && (
        <input
          type="hidden"
          name={name}
          value={joinedValue}
          required={required}
        />
      )}

      {/* Badge row */}
      <div className="flex flex-wrap gap-1.5 items-center">
        <span
          className={`text-[11px] font-medium px-2.5 py-0.5 rounded-full border ${badgeClass}`}
        >
          {badgeText}
        </span>
        {mode === 'seed' && (
          <>
            <button
              type="button"
              onClick={() => setGridSize(12)}
              className={`text-[11px] px-2.5 py-0.5 rounded-full border cursor-pointer transition-colors ${
                gridSize === 12
                  ? 'bg-indigo-50 text-indigo-800 border-indigo-300'
                  : 'bg-transparent text-gray-500 border-gray-200 hover:border-gray-300'
              }`}
            >
              12 words
            </button>
            <button
              type="button"
              onClick={() => setGridSize(24)}
              className={`text-[11px] px-2.5 py-0.5 rounded-full border cursor-pointer transition-colors ${
                gridSize === 24
                  ? 'bg-indigo-50 text-indigo-800 border-indigo-300'
                  : 'bg-transparent text-gray-500 border-gray-200 hover:border-gray-300'
              }`}
            >
              24 words
            </button>
            <button
              type="button"
              onClick={resetToSingle}
              className="ml-auto text-[11px] px-2.5 py-0.5 rounded-full border border-gray-200 bg-transparent text-gray-400 cursor-pointer hover:text-red-500 hover:border-red-300 transition-colors"
            >
              ✕ Clear all
            </button>
          </>
        )}
      </div>

      {/* Label */}
      {label && <div>{label}</div>}

      {/* Single input */}
      {!showGrid && (
        <div className="flex gap-2 items-center">
          <input
            ref={singleRef}
            type={revealed ? 'text' : 'password'}
            className="flex-1 h-11 px-3.5 rounded-lg border border-gray-200 bg-white text-sm font-mono text-gray-900 outline-none focus:border-indigo-400 focus:ring-2 focus:ring-indigo-100 transition-all placeholder:text-gray-300"
            placeholder="0x... or type the first word of your seed phrase"
            value={singleValue}
            onChange={(e) => handleSingleChange(e.target.value)}
            onPaste={handleSinglePaste}
            autoFocus={autoFocus}
            autoComplete="off"
            spellCheck={false}
          />
          {showRevealElement && (
            <button
              type="button"
              onClick={() => setRevealed((r) => !r)}
              title="Show / hide"
              className={`w-11 h-11 shrink-0 rounded-lg border flex items-center justify-center cursor-pointer transition-colors ${
                revealed
                  ? 'border-indigo-400 text-indigo-500 bg-indigo-50'
                  : 'border-gray-200 text-gray-400 bg-gray-50 hover:bg-gray-100'
              }`}
            >
              {revealed ? <EyeOff /> : <EyeOpen />}
            </button>
          )}
        </div>
      )}

      {/* Seed phrase grid */}
      {showGrid && (
        <div className="grid grid-cols-2 gap-2">
          {Array.from({ length: gridSize }, (_, i) => (
            <WordInput
              key={i}
              index={i}
              value={words[i]}
              revealed={revealed}
              isFocused={focusedIndex === i}
              onChange={handleWordChange}
              onKeyDown={handleWordKeyDown}
              onPaste={handleWordPaste}
              onFocus={setFocusedIndex}
              onBlur={() => setFocusedIndex(null)}
              inputRef={(el) => {
                wordRefs.current[i] = el;
              }}
            />
          ))}
        </div>
      )}

      {/* Hint / error */}
      {hint ? (
        <div>{hint}</div>
      ) : (
        <p className="text-[12px] text-gray-400">{hintDefault}</p>
      )}
    </div>
  );
}
